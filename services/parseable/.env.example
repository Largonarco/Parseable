# Required
P_USERNAME=admin
P_PASSWORD=<auto-generated secret>

# Optional - for local store mode (Railway Volume mounted at /data)
P_FS_DIR=/data
P_STAGING_DIR=/data/staging

# Optional - for S3 store mode
# P_S3_URL=https://s3.amazonaws.com
# P_S3_ACCESS_KEY=
# P_S3_SECRET_KEY=
# P_S3_BUCKET=parseable-logs
# P_S3_REGION=us-east-1

# Server
P_ADDR=0.0.0.0:8000
RUST_LOG=warn
P_CORS=false
